# Community Radio Hub — Environment Variables
# Copy to .env.local and fill in your values

# Database (Supabase PostgreSQL)
# Get from: Supabase Dashboard → Project Settings → Database
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres?pgbouncer=true"

# Redis (Upstash) — Sprint 3
# UPSTASH_REDIS_REST_URL="https://..."
# UPSTASH_REDIS_REST_TOKEN="..."

# QStash (cron polling) — Sprint 3
# QSTASH_TOKEN="..."
# QSTASH_CURRENT_SIGNING_KEY="..."
# QSTASH_NEXT_SIGNING_KEY="..."
# POLL_SECRET="your-internal-secret-here"

# Optional
# NEXT_PUBLIC_APP_URL="https://communityradiohub.com.au"
